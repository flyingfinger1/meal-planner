# Auth
AUTH_SECRET=change_me_to_a_random_string

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend URL (used for invite links and post-OAuth redirect)
APP_URL=https://deine-domain.de

# Backend URL (used for Google OAuth callback)
# In production same as APP_URL, in dev http://localhost:3200
BACKEND_URL=https://deine-domain.de

# Database
DB_PATH=/data/meal-planner.sqlite

# SMTP (optional, for invitation emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Meal Planner <noreply@deine-domain.de>

# Invite rate limits (optional, these are the defaults)
# DAILY_INVITE_LIMIT_PER_USER=10
# DAILY_INVITE_LIMIT_PER_EMAIL=3
